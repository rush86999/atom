{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "types": [],
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "downlevelIteration": true,
    "strictNullChecks": false,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@pages/*": [
        "pages/*"
      ],
      "@layouts/*": [
        "layouts/*"
      ],
      "@components/*": [
        "components/*"
      ],
      "@config/*": [
        "config/*"
      ],
      "@lib/*": [
        "lib/*"
      ],
      "@/hooks/*": [
        "hooks/*"
      ],
      "@assets/*": [
        "public/assets/*"
      ],
      "@models": [
        "src/models"
      ],
      "@styles/*": [
        "styles/*"
      ],
      "@shared/*": [
        "../../src/ui-shared/*"
      ],
      "@shared-components/*": [
        "../../src/ui-shared/components/*"
      ],
      "@shared-hooks/*": [
        "../../src/ui-shared/hooks/*"
      ],
      "@shared-services/*": [
        "../../src/services/*"
      ],
      "@shared-ai/*": [
        "../../src/services/ai/*"
      ],
      "@shared-integrations/*": [
        "../../src/services/integrations/*"
      ],
      "@shared-workflows/*": [
        "../../src/services/workflows/*"
      ],
      "@shared-utils/*": [
        "../../src/services/utils/*"
      ],
      "@/orchestration/*": [
        "../../src/orchestration/*"
      ],
      "@/llm/*": [
        "../../src/llm/*"
      ],
      "@/utils/*": [
        "../../src/utils/*"
      ],
      "@atom/test-utils": [
        "./shared/test-utils"
      ],
      "@atom/test-utils/*": [
        "./shared/test-utils/*"
      ],
      "@atom/property-tests": [
        "./shared/property-tests"
      ],
      "@atom/property-tests/*": [
        "./shared/property-tests/*"
      ]
    },
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "next-env.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "project"
  ]
}
