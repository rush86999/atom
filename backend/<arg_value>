@dataclass
class IntegrationPattern:
    """Represents a reusable integration pattern"""
    name: str
    description: str
    methods: List[str]
    imports: List[str]
    dependencies: List[str]
    base_class: Optional[str] = None

@dataclass
class DuplicationMetric:
    """Represents code duplication metrics"""
    pattern: str
    occurrences: int
    total_lines: int
    potential_savings: int
    affected_files: List[str]

class PatternAnalyzer:
    """Analyzes integration services for code duplication patterns"""

    COMMON_PATTERNS = [
        IntegrationPattern(
            name="HTTP Client Setup",
            description="HTTP client initialization and session management",
            methods=["get_session", "close_session", "__aenter__", "__aexit__"],
