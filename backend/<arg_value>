            methods=["check_rate_limit", "handle_rate_limit"],
            imports=["time", "asyncio"],
            dependencies=["RateLimiter"],
            base_class="BaseIntegrationService"
        ),
        IntegrationPattern(
            name="Health Check Implementation",
            description="Service health monitoring",
            methods=["health_check", "ping_service"],
            imports=["datetime", "logging"],
            dependencies=["HealthStatus"],
            base_class="BaseIntegrationService"
        ),
        IntegrationPattern(
            name="Configuration Management",
            description="Service configuration from environment variables",
            methods=["load_config", "validate_config", "get_config"],
            imports=["os", "environ"],
            dependencies=["Config"],
            base_class="BaseIntegrationService"
        )
    ]

    def __init__(self):
        self.patterns = self.COMMON_PATTERNS

    def analyze_service(self, file_path: str) -> Dict[str, Any]:
        """Analyze a service file for patterns"""
        try:
            with open(file_path, 'r', encoding='utf-8') as f:
                content = f.read()

            result = {
                'file': file_path,
                'patterns_found': [],
                'duplications': {},
                'total_lines': len(content.splitlines()),
                'name': Path(file_path).stem.replace('_service', '').title()
            }

            # Check for each pattern
            for pattern in self.patterns:
                pattern_found = False
                occurrences = 0

                # Check method names
                for method in pattern.methods:
                    method_count = content.count(f'def {method}(')
                    if method_count > 0:
                        pattern_found = True
                        occurrences += method_count

                # Check imports
                for import_name in pattern.imports:
                    if import_name in content:
                        pattern_found = True
                        occurrences += content.count(import_name)

                # Check dependency classes
                for dependency in pattern.dependencies:
                    if dependency in content:
                        pattern_found = True
                        occurrences += content.count(dependency)

                if pattern_found:
                    result['patterns_found'].append(pattern.name)
                    result['duplications'][pattern.name] = {
                        'occurrences': occurrences,
                        'methods': pattern.methods,
                        'imports': pattern.imports,
                        'dependencies': pattern.dependencies,
                        'base_class': pattern.base_class
                    }

            # Calculate complexity score
            result['complexity_score'] = self._calculate_complexity_score(result['patterns_found'], result['total_lines'])

            return result

        except Exception as e:
            return {
                'file': file_path,
                'error': str(e),
                'patterns_found': [],
                'duplications': {},
                'total_lines': 0,
                'name': 'Unknown'
            }

    def _calculate_complexity_score(self, patterns_found: List[str], total_lines: int) -> int:
        """Calculate complexity score based on patterns found"""
        base_score = 100
        pattern_scores = {
            "HTTP Client Setup": 10,
            "OAuth Token Management": 15,
            "Error Handling Wrapper": 10,
            "API Key Authentication": 8,
            "Rate Limiting": 12,
            "Health Check Implementation": 8,
            "Configuration Management": 7
        }

        score_reduction = sum(pattern_scores.get(p, 0) for p in patterns_found)
        return max(0, base_score - score_reduction)

    def analyze_all_services(self, integrations_dir: str) -> List[Dict[str, Any]]:
        """Analyze all services in a directory"""
        service_files = list(Path(integrations_dir).glob('*_service.py'))
        analyses = []

        for file_path in service_files:
            analysis = self.analyze_service(str(file_path))
            if 'error' not in analysis:
                analyses.append(analysis)

        return analyses

    def generate_duplication_report(self, analyses: List[Dict[str, Any]]) -> Dict[str, Any]:
        """Generate comprehensive duplication report"""
        all_duplications = {}
        pattern_frequencies = {}
        total_potential_savings = 0

        # Aggregate duplicate data
        for analysis in analyses:
            for pattern_name, duplication_data in analysis['duplications'].items():
                if pattern_name not in all_duplications:
                    all_duplications[pattern_name] = {
                        'pattern_name': pattern_name,
                        'description': next(p.description for p in self.patterns if p.name == pattern_name),
                        'total_occurrences': 0,
                        'total_lines': 0,
                        'affected_services': [],
                        'potential_savings': 0
                    }

                all_duplications[pattern_name]['total_occurrences'] += duplication_data['occurrences']
                all_duplications[pattern_name]['total_lines'] += analysis['total_lines']
                all_duplications[pattern_name]['affected_services'].append(analysis['name'])

                # Calculate potential savings (rough estimate: 50% reduction per occurrence)
                potential_savings = (duplication_data['occurrences'] - 1) * 50
                all_duplications[pattern_name]['potential_savings'] += potential_savings

                pattern_frequencies[pattern_name] = pattern_frequencies.get(pattern_name, 0) + 1

        total_potential_savings = sum(d['potential_savings'] for d in all_duplications.values())
        most_common_patterns = sorted(pattern_frequencies.items(), key=lambda x: x[1], reverse=True)[:10]

        return {
            'total_services': len(analyses),
            'patterns_with_duplications': len(all_duplications),
            'total_potential_savings': total_potential_savings,
            'duplications': all_duplications,
            'most_common_patterns': most_common_patterns,
            'average_complexity_score': sum(a['complexity_score'] for a in analyses) / len(analyses) if analyses else 0,
            'timestamp': datetime.utcnow().isoformat()
        }

