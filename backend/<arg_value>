    def consolidate_service(self, service_name: str, service_file_path: str) -> bool:
        """Create a consolidated version of a service"""
        try:
            print(f"🔧 Consolidating {service_name} service...")

            # Generate template
            template = self.create_base_integration_template(
                service_name=service_name,
                env_var=f"{service_name.upper()}_API_KEY"
            )

            # Create enhanced service file
            enhanced_file_path = service_file_path.replace('.py', '_enhanced.py')
            with open(enhanced_file_path, 'w') as f:
                f.write(template)

            print(f"✅ Created enhanced service: {enhanced_file_path}")

            # Test if enhanced service imports work
            try:
                import import importlib.util
                spec = importlib.util.spec_from_file_location(f"{service_name.lower()}_enhanced", enhanced_file_path)
                module = importlib.util.module_from_spec(spec)
                print(f"✅ Enhanced {service_name} service imports successfully")

                # Test instantiation
                service_class = getattr(module, f"{service_name}Service")
                instance = service_class()
                print(f"✅ Enhanced {service_name} service instantiated successfully")

                self.consolidated_services.append({
                    'name': service_name,
                    'original_file': service_file_path,
                    'enhanced_file': enhanced_file_path,
                    'status': 'success'
                })

                return True

            except Exception as e:
                print(f"❌ Failed to import enhanced {service_name} service: {e}")
                return False

            except Exception as e:
                print(f"❌ Failed to consolidate {service_name} service: {e}")
                return False

        except Exception as e:
            print(f"❌ Error consolidating {service_name}: {e}")
            return False

    def generate_consolidation_plan(self, analyses: List[Dict[str, Any]]) -> Dict[str, Any]:
        """Generate a consolidation plan based on analysis"""
        plan = {
            'timestamp': datetime.utcnow().isoformat(),
            'total_services': len(analyses),
            'high_priority_services': [],
            'medium_priority_services': [],
            'low_priority_services': [],
            'implementation_phases': {}
        }

        # Prioritize services by complexity score (lower score = higher priority)
        sorted_services = sorted(analyses, key=lambda x: x.get('complexity_score', 100))

        # Divide into phases
        high_priority = sorted_services[:5]  # Top 5 most incomplete
        medium_priority = sorted_services[5:10]  # Next 5
        low_priority = sorted_services[10:14]  # Remaining 4 (to reach 14 total)

        plan['high_priority_services'] = [s['name'] for s in high_priority]
        plan['medium_priority_services'] = [s['name'] for s in medium_priority]
        plan['low_priority_services'] = [s['name'] for s in low_priority]
        plan['implementation_phases'] = {
            'phase_1': high_priority[:3],  # First 3 high priority
            'phase_2': high_priority[3:] + medium_priority[:2],  # Next 4
            'phase_3': medium_priority[2:] + low_priority[:5]  # Remaining 7
        }

        return plan

