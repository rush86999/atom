        self.consolidated_services = []

    def analyze_all_services(self) -> Dict[str, Any]:
        """Analyze all integration services for consolidation opportunities"""
        print("🔍 Analyzing integration services for consolidation opportunities...")

        analyses = self.pattern_analyzer.analyze_all_services(self.integrations_dir)
        report = self.pattern_analyzer.generate_duplication_report(analyses)

