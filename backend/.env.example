ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=


# ==============================================================================
# 18. MARKETING & ANALYTICS
# ==============================================================================
# Mailchimp - https://us1.admin.mailchimp.com/account/api/
MAILCHIMP_API_KEY=

# LinkedIn - https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Shopify - https://partners.shopify.com/
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_SHOP_DOMAIN=


# ==============================================================================
# 19. AUDIO / VIDEO / CALENDAR
# ==============================================================================
# Deepgram - https://console.deepgram.com/
DEEPGRAM_API_KEY=

# ElevenLabs - https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Calendly - https://calendly.com/integrations/api_webhooks
CALENDLY_API_KEY=


# ==============================================================================
# 20. EMAIL / SMTP
# ==============================================================================
EMAIL_SERVICE_ENABLED=false
EMAIL_PROVIDER=mailgun
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SOURCE_EMAIL=noreply@atom.ai


# ==============================================================================
# 21. PDF & DOCUMENT PROCESSING
# ==============================================================================
# Requires poppler-utils + tesseract-ocr on the host/container.
ENABLE_PDF_OCR=true
TESSERACT_PATH=/usr/bin/tesseract


# ==============================================================================
# 22. SEARCH & WEB
# ==============================================================================
# Tavily - https://tavily.com/ (agent web-search tool)
TAVILY_API_KEY=
# Brave Search - https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=
# Node.js piece-engine URL (ActivePieces). Only needed if you run the
# piece-engine service (docker-compose.yml default stack).
NODE_ENGINE_URL=http://localhost:3003


# ==============================================================================
# 23. ENHANCED WORKFLOW AUTOMATION
# ==============================================================================
AI_WORKFLOW_ENABLED=true
ENHANCED_MONITORING_ENABLED=true
CROSS_SERVICE_ORCHESTRATION_ENABLED=true
WORKFLOW_OPTIMIZATION_ENABLED=true

# Monitoring thresholds
RESPONSE_TIME_WARNING_MS=1000
RESPONSE_TIME_CRITICAL_MS=5000
SUCCESS_RATE_WARNING=0.95
SUCCESS_RATE_CRITICAL=0.90
HEALTH_SCORE_WARNING=80
HEALTH_SCORE_CRITICAL=60


# ==============================================================================
# 24. GOVERNANCE / FEDERATION / FEATURE FLAGS
# ==============================================================================
ADMIN_GOVERNANCE_ENABLED=true
AGENT_GUIDANCE_ENABLED=true
AGENT_REQUESTS_ENABLED=true
COMMISSION_AUTO_CALCULATE=true

# Federation (cross-instance agent sharing) - optional, private instances.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
FEDERATION_API_KEY=


# ==============================================================================
# 25. MARKETPLACE CONNECTION  (commercial service — atomagentos.com)
# ==============================================================================
# Two equivalent env prefixes are read by the code: ATOM_SAAS_* (below) and
# MARKETPLACE_* (§26). They are aliases; setting either works.

# Marketplace API URL (default: atomagentos.com commercial mothership)
ATOM_SAAS_API_URL=https://atomagentos.com/api/v1/marketplace

# API token — get it from https://atomagentos.com/settings/api-tokens
ATOM_SAAS_API_TOKEN=

# Enable/disable marketplace (default: true). Marketplace features degrade
# gracefully to no-ops when no token is set.
MARKETPLACE_ENABLED=true

# Sync intervals (minutes)
ATOM_SAAS_SYNC_INTERVAL_MINUTES=15
ATOM_SAAS_RATING_SYNC_INTERVAL_MINUTES=30
MARKETPLACE_SYNC_INTERVAL_MINUTES=15
MARKETPLACE_RATING_SYNC_INTERVAL_MINUTES=30

# Conflict resolution: remote_wins | local_wins | merge | manual
ATOM_SAAS_CONFLICT_STRATEGY=remote_wins
MARKETPLACE_CONFLICT_STRATEGY=remote_wins

# WebSocket configuration
ATOM_SAAS_WS_URL=wss://api.atomsaas.com/ws
ATOM_SAAS_WS_RECONNECT_ATTEMPTS=10
ATOM_SAAS_WS_HEARTBEAT_INTERVAL=30
MARKETPLACE_WS_URL=wss://atomagentos.com/ws
MARKETPLACE_WS_RECONNECT_ATTEMPTS=10
MARKETPLACE_WS_HEARTBEAT_INTERVAL=30

# Plain MARKETPLACE_* aliases (same keys as §25, alternate prefix)
MARKETPLACE_API_URL=https://atomagentos.com
MARKETPLACE_API_TOKEN=
MARKETPLACE_SYNC_ENABLED=false


# ==============================================================================
# 26. PYTHON PACKAGE SCANNING
# ==============================================================================
# Safety commercial vulnerability DB API key (optional). Without it, Safety
# uses its free DB (limited coverage). Get one: https://pyup.io/safety/
SAFETY_API_KEY=
PACKAGE_CACHE_TTL=60        # cache duration in seconds
PACKAGE_CACHE_MAX_SIZE=1000 # max cache entries


# ==============================================================================
# 27. PIECE ENGINE SECURITY  (CRITICAL — command-injection fix)
# ==============================================================================
# Required for secure package installation in the Piece Engine. Without it the
# /sys/install and /execute/action endpoints are vulnerable. Only needed when
# running the piece-engine service (docker-compose.yml default stack).
# Generate: openssl rand -base64 32
PIECE_ENGINE_API_KEY=


# ==============================================================================
# NOTES
# ==============================================================================
# OAuth callback URLs use: http://localhost:3000/api/integrations/[service]/callback
# For production, replace with: https://yourdomain.com/api/integrations/[service]/callback
# Full reference: docs/reference/ENVIRONMENT_VARIABLES.md
