PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox


# ==============================================================================
# 17. CLOUD STORAGE (OAuth)
# ==============================================================================
# Dropbox - https://www.dropbox.com/developers/apps
DROPBOX_CLIENT_ID=
DROPBOX_CLIENT_SECRET=
DROPBOX_ACCESS_TOKEN=

# Box - https://app.box.com/developers/console
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=

# Zoho WorkDrive - https://api-console.zoho.com/
# (server-side or web-client app; scope ZohoWorkDrive.files.ALL auto-granted)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
