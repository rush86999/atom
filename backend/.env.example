# ==============================================================================
# ATOM Backend — Environment Configuration
# ==============================================================================
# Copy this file to `.env` and fill in your values:
#     cp backend/.env.example backend/.env
#
# Every variable below has a working default so the app boots out of the box
# on SQLite with no external services. You only NEED to set:
#   1. SECRET_KEY          (required for persistent JWTs — see §2)
#   2. An LLM provider key  (OR ATOM_LOCAL_ONLY=true for Ollama — see §6)
#
# The full reference (every var, its default, and what it does) lives at:
#     docs/reference/ENVIRONMENT_VARIABLES.md
# ==============================================================================


# ==============================================================================
# 1. CORE / RUNTIME
# ==============================================================================
# deployment target. 'production' enforces SECRET_KEY and disables dev escapes.
ENVIRONMENT=development

# FastAPI server bind. Dev launch uses --port 8001 (see README Quick Start);
# these are used when the app reads its own bind config.
HOST=0.0.0.0
PORT=8000

# Uvicorn workers (production). 1 for dev with --reload.
WORKERS=1
DEBUG=true
RELOAD=false

# App's own public URL (used for password-reset links, OAuth redirects, etc.)
APP_URL=http://localhost:3000

# Comma-separated allowed browser origins. The dev frontend runs on :3001.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001
# Same list, read by main_api_app.py (FastAPI CORSMiddleware).
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001

# Lifts auth rate-limiting (register/login). Useful for local dev and the E2E
# suite which create many test users. Leave UNSET in production.
# DISABLE_AUTH_RATE_LIMIT=1


# ==============================================================================
# 2. SECURITY & SECRETS  (REQUIRED — generate strong values for anything real)
# ==============================================================================
# Signs JWT sessions. If unset in development a random one is generated per
# restart (tokens invalidate on every restart). Generate a persistent one:
#   openssl rand -base64 48
SECRET_KEY=atom-secret-key-change-in-production

# JWT lifetime in seconds (default 24h).
JWT_EXPIRATION=86400
# Alternate JWT signing secret name read by some auth paths. If you set
# SECRET_KEY you generally do not need this; if set, it takes precedence for
# those paths. Same value as SECRET_KEY is fine.
# JWT_SECRET_KEY=

# Fernet-style secret encryption key (general secrets at rest). Optional but
# recommended. Generate: openssl rand -base64 32
# ENCRYPTION_KEY=

# BYOK key encryption (encrypts stored provider API keys). Required for the
# integrations/BYOK vault. Generate: openssl rand -base64 32
# BYOK_ENCRYPTION_KEY=

# Allow short-lived dev temp users without full signup. NEVER in production.
ALLOW_DEV_TEMP_USERS=false

# Set the bootstrap admin password yourself (otherwise one is generated and
# written to backend/logs/bootstrap_admin_password.txt on first boot).
# ADMIN_PASSWORD=


# ==============================================================================
# 3. DATABASE
# ==============================================================================
# SQLite = zero external setup (Personal Edition default).
DATABASE_URL=sqlite:///./atom_dev.db
# PostgreSQL (Enterprise / multi-user): uncomment and set a real DSN.
# DATABASE_URL=postgresql://user:password@localhost:5432/atom


# ==============================================================================
# 4. VECTOR STORE & EMBEDDINGS  (always local — FastEmbed / ONNX)
# ==============================================================================
LANCEDB_PATH=./data/lancedb
LANCE_DB_PATH=./data/lancedb
ENABLE_LANCEDB=true
# Cloud (S3/R2) LanceDB paths are gated by this flag. Personal Edition is
# embedded-only (file-based) by default. SaaS edition flips to true.
LANCEDB_CLOUD_ENABLED=false
# Local SQLite path (used when DATABASE_URL is SQLite).
SQLITE_PATH=./data/atom.db


# ==============================================================================
# 5. REDIS & BACKGROUND TASKS  (optional — app runs without Redis)
# ==============================================================================
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

ENABLE_BACKGROUND_TASKS=true
ENABLE_SCHEDULER=true
SCHEDULER_JOB_STORE_TYPE=sqlalchemy
SCHEDULER_JOB_STORE_URL=sqlite:///jobs.sqlite
SCHEDULER_MISFIRE_GRACE_TIME=3600


# ==============================================================================
# 6. AI PROVIDERS  (BYOK — set at least one, OR use Ollama locally)
# ==============================================================================
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Get from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=
# Get from: https://aistudio.google.com/
GOOGLE_API_KEY=
# Get from Z.ai platform (GLM-5.2)
GLM_API_KEY=
# Get from: https://platform.moonshot.cn/ (Kimi K2)
MOONSHOT_API_KEY=
# Get from: https://openrouter.ai/keys  (unified gateway, 300+ models)
OPENROUTER_API_KEY=

# Default model + generation params (used by the AIConfig defaults).
MODEL_NAME=gpt-3.5-turbo
MAX_TOKENS=2048
TEMPERATURE=0.7

# --- Local LLM (Ollama / LM Studio / vLLM — no API key, no cost) ---
# Set ATOM_LOCAL_ONLY=true to block ALL cloud providers and integrations
# (fully offline / maximum privacy). Local providers below still work.
ATOM_LOCAL_ONLY=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3:8b

# Mock AI for tests / offline dev (returns canned responses).
ALLOW_MOCK_AI=true
USE_MOCK_DATA=true
WORKFLOW_MOCK_ENABLED=false

# --- Learning-based LLM router (Phase 3, default OFF) ---
# When true, per-model satisfaction predictors re-rank candidates from observed
# outcomes. Augments (does not replace) the Cognitive Tier System.
ATOM_LEARNING_ROUTER=false
ATOM_EMA_ROUTER_ENABLED=false
ATOM_DAILY_BUDGET=
ATOM_MONTHLY_BUDGET=


# ==============================================================================
# 7. PER-TURN FACT EXTRACTION  (Hermes-style durable memory layer)
#     See docs/architecture/CONTEXT_MEMORY.md
# ==============================================================================
TURN_FACT_EXTRACTION_ENABLED=false   # Per-turn LLM extraction (1 fast-model call/turn)
TURN_FACT_PRE_COMPRESS_ENABLED=true  # Pre-truncation queue (free, additive)
TURN_FACT_VECTOR_RECALL_ENABLED=false # LanceDB-backed semantic recall
TURN_FACT_MAX_PER_TURN=5             # Cap facts persisted per turn
TURN_FACT_EXTRACTION_SAMPLE_RATE=1.0 # Dial down in cost crunch (0.0=off)
TURN_FACT_QUEUE_MAXSIZE=100          # Queue capacity (overflow drops, never blocks)


# ==============================================================================
# 8. API BEHAVIOR
# ==============================================================================
RATE_LIMIT=100            # requests / minute
REQUEST_TIMEOUT=30        # seconds
MAX_REQUEST_SIZE=10485760 # 10 MB
PAGINATION_SIZE=50


# ==============================================================================
# 9. LOGGING
# ==============================================================================
LOG_LEVEL=INFO
LOG_FILE=./logs/atom.log
LOG_MAX_BYTES=10485760  # 10 MB
LOG_BACKUP_COUNT=5


# ==============================================================================
# 10. COMMUNICATION INTEGRATIONS
# ==============================================================================
# Slack - https://api.slack.com/apps
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# Discord - https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_PUBLIC_KEY=

# WhatsApp Cloud API - https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# Telegram Bot API - https://core.telegram.org/bots
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=

# Microsoft Teams (Bot Framework) - https://portal.azure.com/
MICROSOFT_APP_ID=
MICROSOFT_APP_PASSWORD=

# Twilio (SMS) - https://www.twilio.com/console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# SendGrid - https://app.sendgrid.com/
SENDGRID_API_KEY=


# ==============================================================================
# 11. GOOGLE SERVICES (OAuth)
# ==============================================================================
# https://console.cloud.google.com/  Scopes auto-granted: gmail, calendar,
# drive.readonly, drive.file, spreadsheets, userinfo.email.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/integrations/google/callback
# Optional standalone Drive token for dev/convenience.
# GOOGLE_DRIVE_ACCESS_TOKEN=
GOOGLE_DRIVE_API_KEY=


# ==============================================================================
# 12. MICROSOFT (OAuth)
# ==============================================================================
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=


# ==============================================================================
# 13. PROJECT MANAGEMENT (OAuth)
# ==============================================================================
