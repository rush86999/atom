# ============================================================================
# OAuth 2.0 Configuration for LLM Providers
# ============================================================================
#
# This template contains all environment variables needed for OAuth authentication
# with LLM providers (Google AI Studio, OpenAI, Anthropic, Hugging Face).
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to .env.oauth or add to your existing .env file
# 2. Generate OAuth credentials from each provider's developer console
# 3. Fill in the client_id and client_secret for each provider
# 4. Configure the redirect URI to match your application
# 5. Generate an encryption key for token storage (see below)
#
# SECURITY NOTES:
# - NEVER commit these credentials to version control
# - Keep client secrets secure and never share them
# - Use different OAuth apps for development and production
# - Set up proper redirect URI whitelisting in provider consoles
#
# ============================================================================

# ----------------------------------------------------------------------------
# Token Encryption (REQUIRED for production)
# ----------------------------------------------------------------------------
# Generate a Fernet encryption key using:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# IMPORTANT: Store this key securely! If you lose it, all encrypted tokens
# will be permanently unrecoverable.
OAUTH_ENCRYPTION_KEY=your-generated-fernet-key-here

# ----------------------------------------------------------------------------
# OAuth Callback URL
# ----------------------------------------------------------------------------
# This URL must match exactly what you configure in each provider's OAuth app
# Development: http://localhost:8000/api/v1/llm/oauth/callback
# Production: https://your-domain.com/api/v1/llm/oauth/callback
LLM_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/llm/oauth/callback

# ----------------------------------------------------------------------------
# Google AI Studio (Gemini) OAuth
# ----------------------------------------------------------------------------
# Developer Console: https://console.cloud.google.com/
# Setup Instructions:
#   1. Create a new OAuth 2.0 Client ID (Web application)
#   2. Add your redirect URI to "Authorized redirect URIs"
#   3. Scopes required:
#      - https://www.googleapis.com/auth/cloud-platform
#      - https://www.googleapis.com/auth/generative_language.tuning
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# ----------------------------------------------------------------------------
# OpenAI OAuth
# ----------------------------------------------------------------------------
# Developer Console: https://platform.openai.com/
# Setup Instructions:
#   1. Go to Settings → API keys → Create OAuth app
#   2. Configure redirect URI
#   3. Scopes required:
#      - api:model:read
#      - api:model:write
#      - api:completion:read
#      - api:completion:write
OPENAI_OAUTH_CLIENT_ID=your-openai-client-id
OPENAI_OAUTH_CLIENT_SECRET=your-openai-client-secret

# ----------------------------------------------------------------------------
# Anthropic (Claude) OAuth
# ----------------------------------------------------------------------------
# Developer Console: https://console.anthropic.com/
# Setup Instructions:
#   1. OAuth is enterprise-only - contact Anthropic for access
#   2. Create OAuth app in enterprise console
#   3. Scopes required:
#      - api:read
#      - api:write
# NOTE: Anthropic OAuth requires special approval
ANTHROPIC_OAUTH_CLIENT_ID=your-anthropic-client-id
ANTHROPIC_OAUTH_CLIENT_SECRET=your-anthropic-client-secret

# ----------------------------------------------------------------------------
# Hugging Face OAuth
# ----------------------------------------------------------------------------
# Developer Console: https://huggingface.co/settings/connections
# Setup Instructions:
#   1. Create a new OAuth application
#   2. Configure redirect URI
#   3. Scopes required:
#      - read-repos
#      - write-repos
#      - inference-api
HUGGINGFACE_OAUTH_CLIENT_ID=your-huggingface-client-id
HUGGINGFACE_OAUTH_CLIENT_SECRET=your-huggingface-client-secret

# ----------------------------------------------------------------------------
# Optional: Development Settings
# ----------------------------------------------------------------------------

# Enable OAuth debug logging (development only)
OAUTH_DEBUG=false

# Token refresh check interval (seconds)
# How often to check for expiring tokens and refresh them
OAUTH_REFRESH_CHECK_INTERVAL=300

# Token expiration threshold (seconds)
# Refresh tokens this many seconds before expiration
OAUTH_EXPIRATION_THRESHOLD=300

# ----------------------------------------------------------------------------
# Legacy API Key Fallbacks (Optional)
# ----------------------------------------------------------------------------
# These are used as fallbacks when OAuth is not configured
# Google Gemini
GOOGLE_API_KEY=your-google-api-key
# OpenAI
OPENAI_API_KEY=your-openai-api-key
# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key
# Hugging Face
HUGGINGFACE_API_KEY=your-huggingface-api-key

# ============================================================================
# Provider-Specific Setup Guides
# ============================================================================

# GOOGLE AI STUDIO (GEMINI)
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Navigate to APIs & Services → Credentials
# 4. Create Credentials → OAuth client ID → Web application
# 5. Add redirect URI: http://localhost:8000/api/v1/llm/oauth/callback
# 6. Enable APIs:
#    - Cloud AI Platform
#    - Generative Language API
# 7. Copy Client ID and Client Secret

# OPENAI
# 1. Go to https://platform.openai.com/
# 2. Navigate to Settings → API keys
# 3. Click "Create OAuth App"
# 4. Configure:
#    - App name: Your app name
#    - Redirect URIs: http://localhost:8000/api/v1/llm/oauth/callback
#    - Scopes: api:model:read, api:model:write
# 5. Copy Client ID and Client Secret

# ANTHROPIC
# 1. OAuth is enterprise-only
# 2. Contact Anthropic for OAuth access
# 3. Follow enterprise setup guide provided by Anthropic

# HUGGING FACE
# 1. Go to https://huggingface.co/settings/connections
# 2. Click "New OAuth App"
# 3. Configure:
#    - App name: Your app name
#    - Callback URL: http://localhost:8000/api/v1/llm/oauth/callback
#    - Permissions: read-repos, write-repos, inference-api
# 4. Copy OAuth ID and Secret

# ============================================================================
# Troubleshooting
# ============================================================================

# Problem: "redirect_uri_mismatch" error
# Solution: Ensure LLM_OAUTH_REDIRECT_URI matches exactly in provider console
#
# Problem: "invalid_client" error
# Solution: Verify client_id and client_secret are correct
#
# Problem: "access_denied" error
# Solution: User denied permission or scopes not authorized
#
# Problem: Tokens not refreshing
# Solution: Check OAUTH_ENCRYPTION_KEY is set and consistent
#
# Problem: Encryption errors
# Solution: Regenerate OAUTH_ENCRYPTION_KEY (will invalidate existing tokens)

# ============================================================================
# Security Checklist
# ============================================================================
# [ ] OAUTH_ENCRYPTION_KEY is generated and stored securely
# [ ] All client secrets are committed to memory, not git
# [ ] Redirect URIs are whitelisted in provider consoles
# [ ] Different OAuth apps for dev/staging/production
# [ ] Encryption key backed up securely (encrypted)
# [ ] Provider OAuth apps reviewed for minimal scopes
# [ ] Environment variables never logged or exposed
