name: Frontend Tests

on:
  push:
    branches: [main, develop]
    paths:
      - 'frontend-nextjs/**'
  pull_request:
    branches: [main, develop]
    paths:
      - 'frontend-nextjs/**'
  workflow_dispatch:

jobs:
  test:
    name: Frontend Test Suite
    runs-on: ubuntu-latest
    timeout-minutes: 15

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Node.js
        uses: actions/setup-node@v4
        with:
          node-version: '20'
          cache: 'npm'
          cache-dependency-path: frontend-nextjs/package-lock.json

      - name: Install dependencies
        working-directory: ./frontend-nextjs
        run: npm ci --legacy-peer-deps

      - name: Clear Jest cache
        working-directory: ./frontend-nextjs
        run: npx jest --clearCache

      - name: Run tests with coverage
        id: test-coverage
        working-directory: ./frontend-nextjs
        run: npm run test:ci -- --maxWorkers=2

      - name: Check module thresholds
        id: module-coverage
        working-directory: ./frontend-nextjs
        run: |
          node scripts/check-module-coverage.js --reporter=github-actions
        continue-on-error: true

      - name: Generate coverage report
        if: always()
        working-directory: ./frontend-nextjs
        run: |
          if [ -f coverage/coverage-summary.json ]; then
            node scripts/coverage-audit.js --format=markdown > coverage-report.md
            node scripts/coverage-gaps.js --format=markdown >> coverage-report.md
          fi

      - name: Comment PR with coverage report
        if: github.event_name == 'pull_request' && always()
        uses: actions/github-script@v7
        with:
          github-token: ${{ secrets.GITHUB_TOKEN }}
          script: |
            const fs = require('fs');
            const reportPath = 'frontend-nextjs/coverage-report.md';

            if (!fs.existsSync(reportPath)) {
              console.log('Coverage report not found');
              return;
            }

            const report = fs.readFileSync(reportPath, 'utf8');
            const header = '## Frontend Module Coverage Report';

            // Find existing comment
            const { data: comments } = await github.rest.issues.listComments({
              owner: context.repo.owner,
              repo: context.repo.repo,
              issue_number: context.issue.number,
            });

            const botComment = comments.find(comment =>
              comment.user.type === 'Bot' &&
              comment.body.includes(header)
            );

            if (botComment) {
              await github.rest.issues.updateComment({
                owner: context.repo.owner,
                repo: context.repo.repo,
                comment_id: botComment.id,
                body: report,
              });
            } else {
              await github.rest.issues.createComment({
                owner: context.repo.owner,
                repo: context.repo.repo,
                issue_number: context.issue.number,
                body: report,
              });
            }

      - name: Upload coverage artifacts
        if: always()
        uses: actions/upload-artifact@v4
        with:
          name: frontend-coverage-${{ github.sha }}
          path: frontend-nextjs/coverage/
          retention-days: 30

      - name: Upload coverage trend data
        if: github.event_name == 'push' && github.ref == 'refs/heads/main'
        uses: actions/upload-artifact@v4
        with:
          name: frontend-coverage-trend-${{ github.sha }}
          path: frontend-nextjs/coverage/coverage-summary.json
          retention-days: 90

      - name: Generate test results JSON
        working-directory: ./frontend-nextjs
        run: |
          # Run tests again with JSON output for pass rate check
          npm run test:ci -- --json --outputFile=test-results.json --maxWorkers=2

      - name: Check pass rate (98%+ required)
        working-directory: ./frontend-nextjs
        run: |
          if [ -f test-results.json ]; then
            echo "=== Calculating Test Pass Rate ==="

            # Parse test-results.json for pass rate
            PASS_RATE=$(node -e "
              const fs = require('fs');
              try {
                const data = JSON.parse(fs.readFileSync('test-results.json', 'utf8'));
                const total = data.numTotalTests || 0;
                const failed = data.numFailedTests || 0;
                const passed = total - failed;
                const passRate = total > 0 ? ((passed / total) * 100).toFixed(2) : '0.00';
                console.log(passRate);
              } catch (e) {
                console.log('0.00');
              }
            ")

            echo "Pass Rate: ${PASS_RATE}%"

            # Compare with 90% threshold
            if python3 -c "import sys; exit(0 if float('${PASS_RATE}') >= 90.0 else 1)"; then
              echo "✅ Pass rate meets 90% threshold"
            else
              echo "❌ Pass rate below 90% threshold"
              exit 1
            fi
          else
            echo "⚠️ test-results.json not found - using Jest exit code"
            # Exit code check already handled by test step
          fi

      - name: Upload test results
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: frontend-test-results
          path: frontend-nextjs/test-results.json
          retention-days: 7
          if-no-files-found: warn

      - name: Coverage summary
        working-directory: ./frontend-nextjs
        if: always()
        run: |
          if [ -f coverage/coverage-summary.json ]; then
            echo "=== Frontend Coverage Summary ==="
            node -e "
              const fs = require('fs');
              const summary = JSON.parse(fs.readFileSync('coverage/coverage-summary.json', 'utf8'));
              const total = summary.total;
              console.log(\`Lines:   \${total.lines.pct}% (\${total.lines.covered}/\${total.lines.total})\`);
              console.log(\`Branches: \${total.branches.pct}% (\${total.branches.covered}/\${total.branches.total})\`);
              console.log(\`Functions: \${total.functions.pct}% (\${total.functions.covered}/\${total.functions.total})\`);
              console.log(\`Statements: \${total.statements.pct}% (\${total.statements.covered}/\${total.statements.total})\`);
            "
          fi

      - name: Upload coverage audit artifact
        uses: actions/upload-artifact@v4
        if: always()
        with:
          name: frontend-coverage-audit
          path: frontend-nextjs/coverage-audit-report.json
          retention-days: 30
          if-no-files-found: warn

      - name: Fail if module coverage check failed
        if: steps.module-coverage.outcome == 'failure'
        run: exit 1
