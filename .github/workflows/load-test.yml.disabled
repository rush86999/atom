# Load Testing Workflow
#
# Purpose: Automated performance regression detection
#
# Triggers:
# - PR: Quick smoke test (50 users, 2 min) - non-blocking
# - Schedule (daily): Full load test (100 users, 5 min)
# - Manual: On-demand with workflow_dispatch
#
# Baseline Management:
# - baseline.json compared on every run
# - Updated automatically on main branch after successful tests
# - First run will create baseline from template
#
# Artifacts:
# - HTML reports uploaded for 30 days
# - JSON logs available for analysis
#
# To run locally: ./backend/tests/scripts/run_load_tests.sh

name: Load Tests

on:
  pull_request:
    paths:
      - 'backend/core/**'
      - 'backend/api/**'
      - 'backend/tests/load/**'
  schedule:
    - cron: '0 2 * * *'  # Daily at 2 AM UTC
  workflow_dispatch:  # Manual trigger

jobs:
  load-test:
    name: Run Load Tests
    runs-on: ubuntu-large

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.11'
          cache: 'pip'

      - name: Install dependencies
        run: |
          python -m pip install --upgrade pip
          cd backend
          pip install -r requirements.txt
          pip install -r requirements-testing.txt

      - name: Start application
        run: |
          cd backend
          python -m uvicorn main:app --host 0.0.0.0 --port 8000 &
          echo $! > uvicorn.pid
          sleep 10

      - name: Run load tests
        run: |
          cd backend
          # Determine test parameters based on event
          if [ "${{ github.event_name }}" == "pull_request" ]; then
            # Quick smoke test for PRs
            USERS=50
            SPAWN_RATE=5
            DURATION=2m
          else
            # Full load test for schedule and manual
            USERS=100
            SPAWN_RATE=10
            DURATION=5m
          fi

          echo "Running load tests: $USERS users, $SPAWN_RATE spawn rate, $DURATION duration"
          ./tests/scripts/run_load_tests.sh -u $USERS -r $SPAWN_RATE -t $DURATION

      - name: Compare to baseline
        run: |
          cd backend
          python tests/scripts/compare_performance.py \
            tests/load/reports/baseline.json.template \
            tests/load/reports/load_test_*.json \
            --threshold 15

      - name: Upload load test report
        uses: actions/upload-artifact@v4
        with:
          name: load-test-report-${{ github.run_number }}
          path: backend/tests/load/reports/*.html
          retention-days: 30

      - name: Upload load test data
        uses: actions/upload-artifact@v4
        with:
          name: load-test-data-${{ github.run_number }}
          path: backend/tests/load/reports/*.json
          retention-days: 30

      - name: Update baseline
        if: github.ref == 'refs/heads/main'
        run: |
          cd backend
          # Find the most recent load test JSON file
          LATEST_JSON=$(ls -t tests/load/reports/load_test_*.json 2>/dev/null | head -1)

          if [ -z "$LATEST_JSON" ]; then
            echo "No load test results found, skipping baseline update"
            exit 0
          fi

          echo "Updating baseline with: $LATEST_JSON"
          cp "$LATEST_JSON" tests/load/reports/baseline.json

          git config user.name "github-actions[bot]"
          git config user.email "github-actions[bot]@users.noreply.github.com"
          git add tests/load/reports/baseline.json
          git commit -m "Update load test baseline [skip ci]"
          git push

      - name: Shutdown application
        if: always()
        run: |
          cd backend
          if [ -f uvicorn.pid ]; then
            kill $(cat uvicorn.pid) || true
            rm uvicorn.pid
          fi
